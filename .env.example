# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ideahub?schema=public"

# Redis (for job queue)
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-me-in-production"

# AI Provider — uses OpenAI-compatible API so you can point at any provider
# For local models via Ollama: http://localhost:11434/v1
# For vLLM: http://localhost:8000/v1
# For Together AI: https://api.together.xyz/v1
# For OpenAI: https://api.openai.com/v1
AI_BASE_URL="http://localhost:11434/v1"
AI_API_KEY="not-needed-for-ollama"
AI_MODEL="llama3.1:8b"

# Agent Sandbox
AGENT_SANDBOX_IMAGE="ghcr.io/ai-idea-hub/agent-sandbox:latest"
AGENT_MAX_CONCURRENT=5
AGENT_TIMEOUT_SECONDS=300

# AWS (for cloud deployment)
AWS_REGION="eu-north-1"
AWS_ACCOUNT_ID=""
